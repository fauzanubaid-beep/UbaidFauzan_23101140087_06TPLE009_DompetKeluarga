<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_navy">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:titleTextColor="@color/color_white">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laporan Keuangan"
                        android:textColor="@color/color_white"
                        android:textSize="18sp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_sapaan_laporan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pantau ringkasan keuangan Anda di sini"
                        android:textColor="@color/color_white"
                        android:textSize="12sp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_export_pdf"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_download"
                    app:tint="@color/color_white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Unduh Laporan PDF" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
        
        <View android:layout_width="match_parent" android:layout_height="24dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-24dp"
        android:background="@drawable/bg_content_top_curved_cream"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Navigasi bulan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_white"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_card_border"
                app:cardCornerRadius="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton android:id="@+id/btn_prev" 
                        android:layout_width="48dp"
                        android:layout_height="48dp" 
                        android:src="@drawable/ic_chevron_left"
                        android:background="?attr/selectableItemBackgroundBorderless" 
                        app:tint="@color/color_navy"
                        android:contentDescription="Bulan Sebelumnya" />

                    <TextView android:id="@+id/tv_bulan_tahun"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="Juni 2025" android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textSize="17sp" android:textColor="@color/color_navy"/>

                    <ImageButton android:id="@+id/btn_next" 
                        android:layout_width="48dp"
                        android:layout_height="48dp" 
                        android:src="@drawable/ic_chevron_right"
                        android:background="?attr/selectableItemBackgroundBorderless" 
                        app:tint="@color/color_navy"
                        android:contentDescription="Bulan Selanjutnya" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3 Lavender Stat Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_blue_card"
                    android:padding="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pemasukan" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.08"
                        android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_total_pemasukan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rp 0" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textSize="14sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_red_card"
                    android:padding="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pengeluaran" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.08"
                        android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_total_keluar"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rp 0" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textSize="14sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_surplus_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_green_card"
                    android:padding="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_surplus_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Surplus" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.08"
                        android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_total_sisa"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rp 0" android:textColor="@color/color_white"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textSize="14sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
            
            <TextView
                android:id="@+id/tv_insight_surplus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Insight surplus"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/color_blue_dark"
                android:background="@drawable/bg_insight_blue"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="4dp"/>

            <!-- Pie Chart -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Distribusi Pengeluaran" android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/color_heading" android:textSize="15sp"
                android:layout_marginTop="24dp" android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_white"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_card_border"
                app:cardCornerRadius="16dp">
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pie_chart"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_margin="16dp"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_insight_pengeluaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Insight pengeluaran"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/color_blue_dark"
                android:background="@drawable/bg_insight_blue"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="4dp"/>

            <!-- Bar Chart -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Alokasi vs Terpakai" android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/color_heading" android:textSize="15sp"
                android:layout_marginTop="24dp" android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_white"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_card_border"
                app:cardCornerRadius="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scrollbars="none"
                        android:fillViewport="true">
                        
                        <LinearLayout
                            android:id="@+id/custom_bar_chart_container"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom"/>
                        
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_insight_alokasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Insight alokasi"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/color_blue_dark"
                android:background="@drawable/bg_insight_blue"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="4dp"/>

            <View android:layout_width="0dp" android:layout_height="80dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
